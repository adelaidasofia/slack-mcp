# slack-mcp config. Copy to .env and fill in your tokens.
# .env is gitignored. Never commit real tokens.
#
# Each workspace gets a short alias (lowercase). Reference it from tool
# calls via the `workspace` param (default = SLACK_PRIMARY_WORKSPACE).

SLACK_WORKSPACES=onde,mycelium
SLACK_PRIMARY_WORKSPACE=onde

# --- Onde workspace (xoxc browser-session example) ---
SLACK_WORKSPACE_ONDE_TYPE=xoxc
SLACK_WORKSPACE_ONDE_TOKEN=xoxc-REPLACE-WITH-YOUR-TOKEN
SLACK_WORKSPACE_ONDE_COOKIE=xoxd-REPLACE-WITH-YOUR-COOKIE
SLACK_WORKSPACE_ONDE_TEAM_ID=
SLACK_WORKSPACE_ONDE_LABEL=Onde

# --- Mycelium workspace (xoxp OAuth example) ---
SLACK_WORKSPACE_MYCELIUM_TYPE=xoxc
SLACK_WORKSPACE_MYCELIUM_TOKEN=xoxc-REPLACE-WITH-YOUR-TOKEN
SLACK_WORKSPACE_MYCELIUM_COOKIE=xoxd-REPLACE-WITH-YOUR-COOKIE
SLACK_WORKSPACE_MYCELIUM_TEAM_ID=
SLACK_WORKSPACE_MYCELIUM_LABEL=Mycelium

# --- Optional behavior tuning ---
# Vault auto-export of read channels. Set to "false" to disable.
SLACK_MCP_VAULT_EXPORT=true
# Override vault root if your vault isn't at ~/Desktop/Adelaida Notes.
# SLACK_MCP_VAULT_PATH=/path/to/vault

# Audit log path (JSONL). Default: ~/.claude/slack-mcp/audit.log
# SLACK_MCP_AUDIT_LOG_PATH=

# Draft TTL in seconds (default 3600 = 1 hour).
# SLACK_MCP_DRAFT_TTL_SECONDS=3600

# Prompt-injection scrubber. Default true.
# SLACK_MCP_SCRUB_PROMPT_INJECTION=true
